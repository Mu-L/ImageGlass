<StackPanel
    x:Class="ImageGlass.UI.ToolbarSeparator"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:ImageGlass.UI"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="ui:ToolbarItemModel"
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    IsHitTestVisible="False"
    IsVisible="{CompiledBinding IsNotOverflow}"
    Orientation="Horizontal">
    <Line
        Stroke="#3111"
        StrokeLineCap="Round"
        StrokeThickness="1"
        StartPoint="0,0"
        EndPoint="{CompiledBinding SeparatorEndPoint}" />
    <Line
        Stroke="#3eee"
        StrokeLineCap="Round"
        StrokeThickness="1"
        StartPoint="0,0"
        EndPoint="{CompiledBinding SeparatorEndPoint}" />
</StackPanel>

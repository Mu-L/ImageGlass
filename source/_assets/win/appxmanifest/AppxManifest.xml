              <uap:FileType>.raf</uap:FileType>
              <uap:FileType>.raw</uap:FileType>
              <uap:FileType>.rw2</uap:FileType>
              <uap:FileType>.rwl</uap:FileType>
              <uap:FileType>.rwz</uap:FileType>

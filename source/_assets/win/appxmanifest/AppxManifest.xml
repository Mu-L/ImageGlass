<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 desktop rescap">

  <Identity Name="{{IDENTITY_NAME}}" Publisher="{{PUBLISHER}}" Version="{{VERSION}}" ProcessorArchitecture="{{ARCH}}" />

  <Properties>
    <DisplayName>ImageGlass</DisplayName>
    <PublisherDisplayName>{{PUBLISHER_DISPLAY_NAME}}</PublisherDisplayName>
    <Description>A Fast, Seamless Photo Viewer</Description>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Applications>
    <Application Id="IMAGEGLASS" Executable="ImageGlass\ImageGlass.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        BackgroundColor="transparent"
        DisplayName="ImageGlass"
        Square150x150Logo="Assets\IMAGEGLASS-Square150x150Logo.png"
        Square44x44Logo="Assets\IMAGEGLASS-Square44x44Logo.png"
        Description="A Fast, Seamless Photo Viewer">
        <uap:DefaultTile
          Wide310x150Logo="Assets\IMAGEGLASS-Wide310x150Logo.png"
          Square310x310Logo="Assets\IMAGEGLASS-Square310x310Logo.png"
          Square71x71Logo="Assets\IMAGEGLASS-Square71x71Logo.png" />
      </uap:VisualElements>
      <Extensions>
        <uap:Extension Category="windows.fileTypeAssociation" EntryPoint="Windows.FullTrustApplication" Executable="ImageGlass\ImageGlass.exe">
          <uap:FileTypeAssociation Name="imageglass.assocfiles">
            <uap:SupportedFileTypes>
              <uap:FileType>.3fr</uap:FileType>
              <uap:FileType>.apng</uap:FileType>
              <uap:FileType>.ari</uap:FileType>
              <uap:FileType>.arw</uap:FileType>
              <uap:FileType>.avif</uap:FileType>
              <uap:FileType>.b64</uap:FileType>
              <uap:FileType>.bay</uap:FileType>
              <uap:FileType>.bmp</uap:FileType>
              <uap:FileType>.cap</uap:FileType>
              <uap:FileType>.cr2</uap:FileType>
              <uap:FileType>.cr3</uap:FileType>
              <uap:FileType>.crw</uap:FileType>
              <uap:FileType>.cur</uap:FileType>
              <uap:FileType>.cut</uap:FileType>
              <uap:FileType>.dcr</uap:FileType>
              <uap:FileType>.dcs</uap:FileType>
              <uap:FileType>.dds</uap:FileType>
              <uap:FileType>.dib</uap:FileType>
              <uap:FileType>.dng</uap:FileType>
              <uap:FileType>.drf</uap:FileType>
              <uap:FileType>.eip</uap:FileType>
              <uap:FileType>.emf</uap:FileType>
              <uap:FileType>.erf</uap:FileType>
              <uap:FileType>.exif</uap:FileType>
              <uap:FileType>.exr</uap:FileType>
              <uap:FileType>.fax</uap:FileType>
              <uap:FileType>.fff</uap:FileType>
              <uap:FileType>.fits</uap:FileType>
              <uap:FileType>.flif</uap:FileType>
              <uap:FileType>.gif</uap:FileType>
              <uap:FileType>.gifv</uap:FileType>
              <uap:FileType>.gpr</uap:FileType>
              <uap:FileType>.hdp</uap:FileType>
              <uap:FileType>.hdr</uap:FileType>
              <uap:FileType>.heic</uap:FileType>
              <uap:FileType>.heif</uap:FileType>
              <uap:FileType>.hif</uap:FileType>
              <uap:FileType>.ico</uap:FileType>
              <uap:FileType>.iiq</uap:FileType>
              <uap:FileType>.jfif</uap:FileType>
              <uap:FileType>.jp2</uap:FileType>
              <uap:FileType>.jpe</uap:FileType>
              <uap:FileType>.jpeg</uap:FileType>
              <uap:FileType>.jpg</uap:FileType>
              <uap:FileType>.jxl</uap:FileType>
              <uap:FileType>.jxr</uap:FileType>

              <uap:FileType>.xpm</uap:FileType>
              <uap:FileType>.xv</uap:FileType>
            </uap:SupportedFileTypes>
          </uap:FileTypeAssociation>
        </uap:Extension>
        <desktop:Extension Category="windows.fullTrustProcess" Executable="ImageGlass\ImageGlass.exe" />
        <uap3:Extension Category="windows.appExecutionAlias" EntryPoint="Windows.FullTrustApplication" Executable="ImageGlass\ImageGlass.exe">
          <uap3:AppExecutionAlias>
            <desktop:ExecutionAlias Alias="ImageGlass.exe" />
          </uap3:AppExecutionAlias>
        </uap3:Extension>
        <uap:Extension Category="windows.protocol">
          <uap:Protocol Name="imageglass" />
        </uap:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <rescap:Capability Name="broadFileSystemAccess" />
    <rescap:Capability Name="allowElevation" />
  </Capabilities>
</Package>

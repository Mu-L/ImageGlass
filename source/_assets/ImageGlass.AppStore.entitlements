<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox is MANDATORY for Mac App Store distribution. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>

	<!-- Read/write the image file the user explicitly opens or drops. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>

	<!-- Persist access to folders across launches via security-scoped bookmarks.
	     REQUIRED for ImageGlass's next/previous browsing of sibling files in the
	     containing folder. Without adopting bookmarks in the Mac file providers,
	     the sandbox only grants access to the single opened file. -->
	<key>com.apple.security.files.bookmarks.app-scope</key>
	<true/>

	<!-- .NET / Avalonia / Skia may map executable memory at runtime. allow-jit is
	     accepted by App Store review. We do NOT disable library validation here:
	     every bundled dylib is signed with the same Apple Distribution identity,
	     so library validation passes on its own (disabling it draws review scrutiny). -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
</dict>
</plist>

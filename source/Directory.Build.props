<Project>
  <PropertyGroup>
    <!-- Central app version: change ONLY here to update all platform projects.
      Each executable project sets <IgPlatformId> (e.g. win32, mac, linux).
      IgFullVersion is composed in Directory.Build.targets after all properties are set. -->
    <IgVersion>10.0.0.531</IgVersion>
    <IgReleaseType>beta</IgReleaseType>
    <IgUpdateChannel>beta</IgUpdateChannel>

    <!-- App bundle version. Leave empty to derive from IgVersion.
      - IgBundleShortVersion -> CFBundleShortVersionString: marketing version,
        1-3 integers (e.g. 10.0.0).
      - IgBundleBuild -> CFBundleVersion: build number, 1-3 integers; must
        INCREASE with every App Store upload for the same short version. -->
    <IgBundleShortVersion>10.0.0</IgBundleShortVersion>
    <IgBundleBuild>533</IgBundleBuild>
  </PropertyGroup>
</Project>

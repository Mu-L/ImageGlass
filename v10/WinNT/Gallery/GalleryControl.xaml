<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ImageGlass.WinNT.GalleryControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.WinNT"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    SizeChanged="UserControl_SizeChanged"
    mc:Ignorable="d">


    <ScrollViewer
        x:Name="GalleryScrollViewer"
        Padding="0,5,0,5"
        HorizontalScrollBarVisibility="Auto"
        HorizontalScrollMode="Enabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Disabled"
        ViewChanging="GalleryScrollViewer_ViewChanging">
        <ItemsRepeater x:Name="GalleryItemRepeater" HorizontalAlignment="Center">
            <ItemsRepeater.Layout>
                <UniformGridLayout
                    MinColumnSpacing="5"
                    MinItemHeight="70"
                    MinItemWidth="70"
                    MinRowSpacing="5"
                    Orientation="Horizontal" />
            </ItemsRepeater.Layout>

            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Button
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{x:Bind}"
                        Click="GalleryItem_Selected"
                        Content="{x:Bind}"
                        Foreground="{ThemeResource ButtonForeground}"
                        GotFocus="GalleryItem_Selected" />
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
    </ScrollViewer>


</UserControl>

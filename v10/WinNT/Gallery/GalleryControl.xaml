<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ImageGlass.WinNT.GalleryControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.WinNT"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:photoing="using:ImageGlass.WinNT.Common.Photoing"
    SizeChanged="UserControl_SizeChanged"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="GalleryItemTemplate" x:DataType="x:String">
            <Button
                Padding="2,0,2,2.5"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Bottom"
                Click="GalleryItem_Selected">
                <Grid VerticalAlignment="Bottom">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Image Grid.Row="0" Source="null" />
                    <TextBlock
                        Grid.Row="1"
                        VerticalAlignment="Bottom"
                        Foreground="{ThemeResource ButtonForeground}"
                        Text="{x:Bind}" />
                </Grid>
            </Button>
        </DataTemplate>
    </UserControl.Resources>



    <ScrollViewer
        x:Name="GalleryScrollViewer"
        Padding="5"
        HorizontalScrollBarVisibility="Auto"
        HorizontalScrollMode="Enabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Disabled">
        <ItemsRepeater
            x:Name="GalleryItemRepeater"
            HorizontalAlignment="Center"
            ItemTemplate="{StaticResource GalleryItemTemplate}">
            <ItemsRepeater.Layout>
                <UniformGridLayout
                    ItemsStretch="Uniform"
                    MinColumnSpacing="5"
                    MinItemHeight="{x:Bind ItemSize}"
                    MinItemWidth="{x:Bind ItemSize}"
                    MinRowSpacing="5"
                    Orientation="Horizontal" />
            </ItemsRepeater.Layout>
        </ItemsRepeater>
    </ScrollViewer>

</UserControl>

<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ImageGlass.WinNT.GalleryControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.WinNT"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:photoing="using:ImageGlass.WinNT.Common.Photoing"
    d:DataContext="{d:DesignInstance local:GalleryControl,
                                     IsDesignTimeCreatable=True}"
    SizeChanged="UserControl_SizeChanged"
    Unloaded="UserControl_Unloaded"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  Gallery Item: Template  -->
        <DataTemplate x:Key="GalleryItemTemplate" x:DataType="photoing:Photo">
            <Button
                Padding="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Click="GalleryItem_Selected">
                <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Gallery Item: Thumbnail  -->
                    <Image
                        Name="GalleryItem_Thumbnail"
                        Grid.Row="0"
                        Stretch="Uniform" />


                    <!--  Gallery Item: Title  -->
                    <Grid
                        Grid.Row="1"
                        Padding="2,0,2,0"
                        HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Text="{x:Bind GalleryFileTitle}"
                            TextTrimming="CharacterEllipsis" />

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Text="{x:Bind GalleryFileExt}"
                            Visibility="Visible" />
                    </Grid>
                </Grid>
            </Button>
        </DataTemplate>
    </UserControl.Resources>



    <ScrollViewer
        x:Name="GalleryScrollViewer"
        Padding="5"
        HorizontalScrollBarVisibility="Auto"
        HorizontalScrollMode="Enabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Disabled">
        <ItemsRepeater
            x:Name="GalleryItemRepeater"
            HorizontalAlignment="Center"
            ElementPrepared="GalleryItemRepeater_ElementPrepared"
            ItemTemplate="{StaticResource GalleryItemTemplate}">
            <ItemsRepeater.Layout>
                <UniformGridLayout
                    ItemsStretch="Uniform"
                    MinColumnSpacing="5"
                    MinItemHeight="{x:Bind ItemSize}"
                    MinItemWidth="{x:Bind ItemSize}"
                    MinRowSpacing="5"
                    Orientation="Horizontal" />
            </ItemsRepeater.Layout>
        </ItemsRepeater>
    </ScrollViewer>

</UserControl>

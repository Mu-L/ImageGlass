<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ImageGlass.WinNT.GalleryControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.WinNT"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:photoing="using:ImageGlass.WinNT.Common.Photoing"
    SizeChanged="UserControl_SizeChanged"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="GalleryItemTemplate" x:DataType="x:String">
            <Button Click="GalleryItem_Selected" GotFocus="GalleryItem_Selected">
                <StackPanel>
                    <Image Source="null" />
                    <TextBlock Foreground="{ThemeResource ButtonForeground}" Text="{x:Bind}" />
                </StackPanel>
            </Button>
        </DataTemplate>
    </UserControl.Resources>



    <ScrollViewer
        x:Name="GalleryScrollViewer"
        Padding="0,5,0,5"
        HorizontalScrollBarVisibility="Auto"
        HorizontalScrollMode="Enabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Disabled"
        ViewChanging="GalleryScrollViewer_ViewChanging">
        <ItemsRepeater
            x:Name="GalleryItemRepeater"
            HorizontalAlignment="Center"
            ItemTemplate="{StaticResource GalleryItemTemplate}">
            <ItemsRepeater.Layout>
                <UniformGridLayout
                    MinColumnSpacing="5"
                    MinItemHeight="70"
                    MinItemWidth="70"
                    MinRowSpacing="5"
                    Orientation="Horizontal" />
            </ItemsRepeater.Layout>
        </ItemsRepeater>
    </ScrollViewer>

</UserControl>

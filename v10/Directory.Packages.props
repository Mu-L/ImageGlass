    <PackageVersion Include="AvaloniaUI.DiagnosticsSupport" Version="2.2.0" />
    <PackageVersion Include="D2Phap.EggShell-ARM64" Version="1.1.208" />
    <PackageVersion Include="D2Phap.EggShell-x64" Version="1.1.208" />
    <PackageVersion Include="D2Phap.FileWatcherEx" Version="3.0.0" />
    <PackageVersion Include="Magick.NET-Q8-arm64" Version="14.11.1" />
    <PackageVersion Include="Magick.NET-Q8-OpenMP-arm64" Version="14.11.1" />
    <PackageVersion Include="Magick.NET-Q8-OpenMP-x64" Version="14.11.1" />

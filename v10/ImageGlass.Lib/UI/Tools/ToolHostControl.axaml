<ui:PhControl
    x:Class="ImageGlass.UI.ToolHostControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:ImageGlass.UI"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:Name="Root">

    <ui:PhControl.Resources>
        <StreamGeometry x:Key="IconClose">M 0,0 L 10,10 M 10,0 L 0,10</StreamGeometry>
        <StreamGeometry x:Key="IconSettings">M12,15.5 A3.5,3.5 0 1 1 12,8.5 A3.5,3.5 0 1 1 12,15.5 M19.43,12.98 C19.47,12.66 19.5,12.34 19.5,12 C19.5,11.66 19.47,11.34 19.43,11.02 L21.54,9.37 C21.73,9.22 21.78,8.95 21.66,8.73 L19.66,5.27 C19.54,5.05 19.27,4.97 19.05,5.05 L16.56,6.05 C16.04,5.65 15.48,5.32 14.87,5.07 L14.49,2.42 C14.46,2.18 14.25,2 14,2 L10,2 C9.75,2 9.54,2.18 9.51,2.42 L9.13,5.07 C8.52,5.32 7.96,5.65 7.44,6.05 L4.95,5.05 C4.73,4.97 4.46,5.05 4.34,5.27 L2.34,8.73 C2.21,8.95 2.27,9.22 2.46,9.37 L4.57,11.02 C4.53,11.34 4.5,11.66 4.5,12 C4.5,12.34 4.53,12.66 4.57,12.98 L2.46,14.63 C2.27,14.78 2.21,15.05 2.34,15.27 L4.34,18.73 C4.46,18.95 4.73,19.03 4.95,18.95 L7.44,17.95 C7.96,18.35 8.52,18.68 9.13,18.93 L9.51,21.58 C9.54,21.82 9.75,22 10,22 L14,22 C14.25,22 14.46,21.82 14.49,21.58 L14.87,18.93 C15.48,18.68 16.04,18.35 16.56,17.95 L19.05,18.95 C19.27,19.03 19.54,18.95 19.66,18.73 L21.66,15.27 C21.78,15.05 21.73,14.78 21.54,14.63 L19.43,12.98 Z</StreamGeometry>
    </ui:PhControl.Resources>


    <ui:PhControl.Styles>
        <!--  Target the Path inside the CloseButton  -->
        <Style Selector=".tool_button Path">
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector=".tool_button:pointerover Path">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </ui:PhControl.Styles>


    <ui:PhControl.Content>
        <Grid ColumnDefinitions="*,Auto">
            <!--  The slot for hosted tool content  -->
            <ContentControl
                Grid.Column="0"
                BorderBrush="{DynamicResource IG_BorderNeutralBrush}"
                BorderThickness="0,1"
                Content="{CompiledBinding #Root.ToolContent}" />


            <!--  Close button  -->
            <StackPanel
                Margin="4"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Spacing="4"
                ZIndex="100">
                <!--  Close button  -->
                <ui:PhToolButton
                    x:Name="PART_BtnClose"
                    Padding="6"
                    Classes="tool_button"
                    Click="PART_BtnClose_Click"
                    ToolTip.Tip="{CompiledBinding #Root.CloseButtonTooltipText}">
                    <Path
                        Width="10"
                        Height="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="{StaticResource IconClose}"
                        Stretch="Uniform"
                        Stroke="{DynamicResource IG_ThemeForegroundBrush}"
                        StrokeThickness="1" />
                </ui:PhToolButton>

                <!--  Settings button  -->
                <ui:PhToolButton
                    x:Name="PART_BtnSettings"
                    Padding="6"
                    Classes="tool_button"
                    Click="PART_BtnSettings_Click"
                    IsVisible="{CompiledBinding #Root.HasSettings}"
                    ToolTip.Tip="{CompiledBinding #Root.SettingsButtonTooltipText}">
                    <Path
                        Width="10"
                        Height="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="{StaticResource IconSettings}"
                        Stretch="Uniform"
                        Stroke="{DynamicResource IG_ThemeForegroundBrush}"
                        StrokeThickness="1" />
                </ui:PhToolButton>
            </StackPanel>
        </Grid>
    </ui:PhControl.Content>
</ui:PhControl>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- WinUI 3-style ScrollBar resources -->
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <!-- Thumb -->
      <SolidColorBrush x:Key="IG_ScrollBarThumbFill" Color="#8A8A8A" />
      <SolidColorBrush x:Key="IG_ScrollBarThumbFillPointerOver" Color="#6B6B6B" />
      <SolidColorBrush x:Key="IG_ScrollBarThumbFillPressed" Color="#5A5A5A" />
      <SolidColorBrush x:Key="IG_ScrollBarThumbFillDisabled" Color="#30808080" />

      <!-- Track -->
      <SolidColorBrush x:Key="IG_ScrollBarTrackFill" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarTrackFillPointerOver" Color="#08000000" />
      <SolidColorBrush x:Key="IG_ScrollBarTrackStroke" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarTrackStrokePointerOver" Color="Transparent" />

      <!-- Arrow buttons -->
      <SolidColorBrush x:Key="IG_ScrollBarButtonArrowForeground" Color="#8A8A8A" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonArrowForegroundPointerOver" Color="#5A5A5A" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonArrowForegroundPressed" Color="#8A8A8A" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonArrowForegroundDisabled" Color="#30808080" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBackground" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBackgroundPointerOver" Color="#08000000" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBackgroundPressed" Color="#10000000" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBackgroundDisabled" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBorderBrush" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBorderBrushPointerOver" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBorderBrushPressed" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBorderBrushDisabled" Color="Transparent" />

      <!-- Background -->
      <SolidColorBrush x:Key="IG_ScrollBarBackground" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarBackgroundPointerOver" Color="#06000000" />
      <SolidColorBrush x:Key="IG_ScrollBarBorderBrush" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarForeground" Color="#6B6B6B" />
      <SolidColorBrush x:Key="IG_ScrollBarThumbBackgroundColor" Color="#6B6B6B" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <!-- Thumb -->
      <SolidColorBrush x:Key="IG_ScrollBarThumbFill" Color="#A0A0A0" />
      <SolidColorBrush x:Key="IG_ScrollBarThumbFillPointerOver" Color="#BFBFBF" />
      <SolidColorBrush x:Key="IG_ScrollBarThumbFillPressed" Color="#999999" />
      <SolidColorBrush x:Key="IG_ScrollBarThumbFillDisabled" Color="#30808080" />

      <!-- Track -->
      <SolidColorBrush x:Key="IG_ScrollBarTrackFill" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarTrackFillPointerOver" Color="#0CFFFFFF" />
      <SolidColorBrush x:Key="IG_ScrollBarTrackStroke" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarTrackStrokePointerOver" Color="Transparent" />

      <!-- Arrow buttons -->
      <SolidColorBrush x:Key="IG_ScrollBarButtonArrowForeground" Color="#A0A0A0" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonArrowForegroundPointerOver" Color="#BFBFBF" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonArrowForegroundPressed" Color="#A0A0A0" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonArrowForegroundDisabled" Color="#30808080" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBackground" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBackgroundPointerOver" Color="#0CFFFFFF" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBackgroundPressed" Color="#15FFFFFF" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBackgroundDisabled" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBorderBrush" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBorderBrushPointerOver" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBorderBrushPressed" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarButtonBorderBrushDisabled" Color="Transparent" />

      <!-- Background -->
      <SolidColorBrush x:Key="IG_ScrollBarBackground" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarBackgroundPointerOver" Color="#0AFFFFFF" />
      <SolidColorBrush x:Key="IG_ScrollBarBorderBrush" Color="Transparent" />
      <SolidColorBrush x:Key="IG_ScrollBarForeground" Color="#A0A0A0" />
      <SolidColorBrush x:Key="IG_ScrollBarThumbBackgroundColor" Color="#BFBFBF" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>


  <!--
    WinUI 3 metrics:
    - Track area is 14px wide (enough for hit-testing)
    - Thumb layout width is 6px (pill shape)
    - Collapsed: ScaleTransform shrinks thumb to ~2px visual
    - Expanded: RenderTransform=none shows the 6px pill
  -->
  <x:Double x:Key="IG_ScrollBarSize">14</x:Double>
  <x:Double x:Key="IG_ScrollBarThumbSize">6</x:Double>
  <x:Double x:Key="IG_ScrollBarButtonArrowIconLong">10</x:Double>
  <x:Double x:Key="IG_ScrollBarButtonArrowIconShort">7.5</x:Double>
  <x:Double x:Key="IG_ScrollBarTrackBorderThemeThickness">0</x:Double>

  <!-- Collapsed: scale the 6px thumb to ~2px (0.33 * 6 = 2) -->
  <ScaleTransform x:Key="IG_VerticalSmallScrollThumbScaleTransform" ScaleX="0.33" ScaleY="1" />
  <ScaleTransform x:Key="IG_HorizontalSmallScrollThumbScaleTransform" ScaleX="1" ScaleY="0.33" />


  <!-- Thumb theme: pill-shaped with fully rounded corners -->
  <ControlTheme x:Key="IG_ScrollBarThumb" TargetType="Thumb">
    <Setter Property="Background" Value="{DynamicResource IG_ScrollBarThumbFill}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  CornerRadius="{TemplateBinding CornerRadius}" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Setter Property="Transitions">
      <Transitions>
        <CornerRadiusTransition Property="CornerRadius" Duration="0:0:0.1" />
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
      </Transitions>
    </Setter>

    <Style Selector="^:pointerover /template/ Border">
      <Setter Property="Background" Value="{DynamicResource IG_ScrollBarThumbFillPointerOver}" />
    </Style>
    <Style Selector="^:pressed /template/ Border">
      <Setter Property="Background" Value="{DynamicResource IG_ScrollBarThumbFillPressed}" />
    </Style>
    <Style Selector="^:disabled /template/ Border">
      <Setter Property="Background" Value="{DynamicResource IG_ScrollBarThumbFillDisabled}" />
    </Style>
  </ControlTheme>


  <!-- Page (track area) button: invisible hit-test area -->
  <ControlTheme x:Key="IG_ScrollBarPageButton" TargetType="RepeatButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}" />
      </ControlTemplate>
    </Setter>
  </ControlTheme>


  <!-- Line (arrow) button: hidden by default, shown on expanded state -->
  <ControlTheme x:Key="IG_ScrollBarLineButton" TargetType="RepeatButton">
    <Setter Property="Opacity" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource IG_ScrollBarButtonArrowForeground}" />
    <Setter Property="Template">
      <ControlTemplate>
        <ContentPresenter x:Name="PART_ContentPresenter"
                          Background="{DynamicResource IG_ScrollBarButtonBackground}"
                          BorderBrush="{DynamicResource IG_ScrollBarButtonBorderBrush}"
                          Content="{TemplateBinding Content}" />
      </ControlTemplate>
    </Setter>
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
      </Transitions>
    </Setter>

    <Style Selector="^:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource IG_ScrollBarButtonArrowForegroundPointerOver}" />
      <Style Selector="^ /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource IG_ScrollBarButtonBackgroundPointerOver}" />
        <Setter Property="BorderBrush" Value="{DynamicResource IG_ScrollBarButtonBorderBrushPointerOver}" />
      </Style>
    </Style>

    <Style Selector="^:pressed">
      <Setter Property="Foreground" Value="{DynamicResource IG_ScrollBarButtonArrowForegroundPressed}" />
      <Style Selector="^ /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource IG_ScrollBarButtonBackgroundPressed}" />
        <Setter Property="BorderBrush" Value="{DynamicResource IG_ScrollBarButtonBorderBrushPressed}" />
      </Style>
    </Style>

    <Style Selector="^:disabled">
      <Setter Property="Foreground" Value="{DynamicResource IG_ScrollBarButtonArrowForegroundDisabled}" />
      <Style Selector="^ /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource IG_ScrollBarButtonBackgroundDisabled}" />
        <Setter Property="BorderBrush" Value="{DynamicResource IG_ScrollBarButtonBorderBrushDisabled}" />
      </Style>
    </Style>
  </ControlTheme>


  <!-- Main ScrollBar ControlTheme (WinUI 3 style) -->
  <ControlTheme x:Key="{x:Type ScrollBar}" TargetType="ScrollBar">
    <Setter Property="MinWidth" Value="{DynamicResource IG_ScrollBarSize}" />
    <Setter Property="MinHeight" Value="{DynamicResource IG_ScrollBarSize}" />
    <Setter Property="Background" Value="{DynamicResource IG_ScrollBarBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource IG_ScrollBarForeground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource IG_ScrollBarBorderBrush}" />

    <!-- ===== VERTICAL ===== -->
    <Style Selector="^:vertical">
      <Setter Property="Template">
        <ControlTemplate>
          <Grid x:Name="Root">
            <Border x:Name="VerticalRoot"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    CornerRadius="6">
              <Grid RowDefinitions="Auto,*,Auto">
                <Rectangle x:Name="TrackRect"
                           Fill="{DynamicResource IG_ScrollBarTrackFill}"
                           Stroke="{DynamicResource IG_ScrollBarTrackStroke}"
                           StrokeThickness="{DynamicResource IG_ScrollBarTrackBorderThemeThickness}"
                           RadiusX="6" RadiusY="6"
                           Opacity="0"
                           Grid.RowSpan="3">
                  <Rectangle.Transitions>
                    <Transitions>
                      <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                    </Transitions>
                  </Rectangle.Transitions>
                </Rectangle>

                <RepeatButton Name="PART_LineUpButton"
                              HorizontalAlignment="Center"
                              Theme="{StaticResource IG_ScrollBarLineButton}"
                              Grid.Row="0"
                              Focusable="False"
                              MinWidth="{DynamicResource IG_ScrollBarSize}"
                              Height="{DynamicResource IG_ScrollBarSize}"
                              AutomationProperties.Name="Line up">
                  <PathIcon Data="M 3,9.5 L 7,2.8 Q 8,1 9,2.8 L 13,9.5 Q 14,11.5 12,11.5 L 4,11.5 Q 2,11.5 3,9.5 Z"
                            Width="{DynamicResource IG_ScrollBarButtonArrowIconLong}"
                            Height="{DynamicResource IG_ScrollBarButtonArrowIconShort}"
                            Foreground="{Binding $parent[RepeatButton].Foreground}" />
                </RepeatButton>

                <Track Grid.Row="1"
                       Minimum="{TemplateBinding Minimum}"
                       Maximum="{TemplateBinding Maximum}"
                       Value="{TemplateBinding Value, Mode=TwoWay}"
                       DeferThumbDrag="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                       ViewportSize="{TemplateBinding ViewportSize}"
                       Orientation="{TemplateBinding Orientation}"
                       IsDirectionReversed="True">
                  <Track.DecreaseButton>
                    <RepeatButton Name="PART_PageUpButton"
                                  Classes="largeIncrease"
                                  Theme="{StaticResource IG_ScrollBarPageButton}"
                                  Focusable="False"
                                  AutomationProperties.Name="Page up" />
                  </Track.DecreaseButton>
                  <Track.IncreaseButton>
                    <RepeatButton Name="PART_PageDownButton"
                                  Classes="largeIncrease"
                                  Theme="{StaticResource IG_ScrollBarPageButton}"
                                  Focusable="False"
                                  AutomationProperties.Name="Page down" />
                  </Track.IncreaseButton>
                  <!-- Thumb: 6px layout width, visually scaled to ~2px when collapsed -->
                  <Thumb Theme="{StaticResource IG_ScrollBarThumb}"
                         Width="{DynamicResource IG_ScrollBarThumbSize}"
                         MinHeight="{DynamicResource IG_ScrollBarSize}"
                         CornerRadius="3"
                         RenderTransform="{DynamicResource IG_VerticalSmallScrollThumbScaleTransform}"
                         RenderTransformOrigin="100%,50%"
                         AutomationProperties.Name="Position" />
                </Track>

                <RepeatButton Name="PART_LineDownButton"
                              HorizontalAlignment="Center"
                              Theme="{StaticResource IG_ScrollBarLineButton}"
                              Grid.Row="2"
                              Focusable="False"
                              MinWidth="{DynamicResource IG_ScrollBarSize}"
                              Height="{DynamicResource IG_ScrollBarSize}"
                              AutomationProperties.Name="Line down">
                  <PathIcon Data="M 13,2.5 L 9,9.2 Q 8,11 7,9.2 L 3,2.5 Q 2,0.5 4,0.5 L 12,0.5 Q 14,0.5 13,2.5 Z"
                            Width="{DynamicResource IG_ScrollBarButtonArrowIconLong}"
                            Height="{DynamicResource IG_ScrollBarButtonArrowIconShort}"
                            Foreground="{Binding $parent[RepeatButton].Foreground}" />
                </RepeatButton>
              </Grid>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>

    <!-- ===== HORIZONTAL ===== -->
    <Style Selector="^:horizontal">
      <Setter Property="Template">
        <ControlTemplate>
          <Grid x:Name="Root">
            <Border x:Name="HorizontalRoot"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    CornerRadius="6">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <Rectangle x:Name="TrackRect"
                           Fill="{DynamicResource IG_ScrollBarTrackFill}"
                           Stroke="{DynamicResource IG_ScrollBarTrackStroke}"
                           StrokeThickness="{DynamicResource IG_ScrollBarTrackBorderThemeThickness}"
                           RadiusX="6" RadiusY="6"
                           Opacity="0"
                           Grid.ColumnSpan="3">
                  <Rectangle.Transitions>
                    <Transitions>
                      <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                    </Transitions>
                  </Rectangle.Transitions>
                </Rectangle>

                <RepeatButton Name="PART_LineUpButton"
                              Theme="{StaticResource IG_ScrollBarLineButton}"
                              VerticalAlignment="Center"
                              Grid.Column="0"
                              Focusable="False"
                              MinHeight="{DynamicResource IG_ScrollBarSize}"
                              Width="{DynamicResource IG_ScrollBarSize}"
                              AutomationProperties.Name="Column left">
                  <PathIcon Data="M 9.5,3 L 2.8,7 Q 1,8 2.8,9 L 9.5,13 Q 11.5,14 11.5,12 L 11.5,4 Q 11.5,2 9.5,3 Z"
                            Width="{DynamicResource IG_ScrollBarButtonArrowIconShort}"
                            Height="{DynamicResource IG_ScrollBarButtonArrowIconLong}"
                            Foreground="{Binding $parent[RepeatButton].Foreground}" />
                </RepeatButton>

                <Track Grid.Column="1"
                       Minimum="{TemplateBinding Minimum}"
                       Maximum="{TemplateBinding Maximum}"
                       Value="{TemplateBinding Value, Mode=TwoWay}"
                       DeferThumbDrag="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                       ViewportSize="{TemplateBinding ViewportSize}"
                       Orientation="{TemplateBinding Orientation}">
                  <Track.DecreaseButton>
                    <RepeatButton Name="PART_PageUpButton"
                                  Classes="largeIncrease"
                                  Theme="{StaticResource IG_ScrollBarPageButton}"
                                  Focusable="False"
                                  AutomationProperties.Name="Page left" />
                  </Track.DecreaseButton>
                  <Track.IncreaseButton>
                    <RepeatButton Name="PART_PageDownButton"
                                  Classes="largeIncrease"
                                  Theme="{StaticResource IG_ScrollBarPageButton}"
                                  Focusable="False"
                                  AutomationProperties.Name="Page right" />
                  </Track.IncreaseButton>
                  <!-- Thumb: 6px layout height, visually scaled to ~2px when collapsed -->
                  <Thumb Theme="{StaticResource IG_ScrollBarThumb}"
                         Height="{DynamicResource IG_ScrollBarThumbSize}"
                         MinWidth="{DynamicResource IG_ScrollBarSize}"
                         CornerRadius="3"
                         RenderTransform="{DynamicResource IG_HorizontalSmallScrollThumbScaleTransform}"
                         RenderTransformOrigin="50%,100%"
                         AutomationProperties.Name="Position" />
                </Track>

                <RepeatButton Name="PART_LineDownButton"
                              Theme="{StaticResource IG_ScrollBarLineButton}"
                              VerticalAlignment="Center"
                              Grid.Column="2"
                              Focusable="False"
                              MinHeight="{DynamicResource IG_ScrollBarSize}"
                              Width="{DynamicResource IG_ScrollBarSize}"
                              AutomationProperties.Name="Column right">
                  <PathIcon Data="M 2.5,3 L 9.2,7 Q 11,8 9.2,9 L 2.5,13 Q 0.5,14 0.5,12 L 0.5,4 Q 0.5,2 2.5,3 Z"
                            Width="{DynamicResource IG_ScrollBarButtonArrowIconShort}"
                            Height="{DynamicResource IG_ScrollBarButtonArrowIconLong}"
                            Foreground="{Binding $parent[RepeatButton].Foreground}" />
                </RepeatButton>
              </Grid>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>

    <!-- ===== EXPANDED STATE (pointer over scrollbar area) ===== -->
    <Style Selector="^[IsExpanded=true]">
      <Style Selector="^ /template/ Border#VerticalRoot">
        <Setter Property="Background" Value="{DynamicResource IG_ScrollBarBackgroundPointerOver}" />
      </Style>
      <Style Selector="^ /template/ Border#HorizontalRoot">
        <Setter Property="Background" Value="{DynamicResource IG_ScrollBarBackgroundPointerOver}" />
      </Style>
      <Style Selector="^ /template/ Rectangle#TrackRect">
        <Setter Property="Fill" Value="{DynamicResource IG_ScrollBarTrackFillPointerOver}" />
        <Setter Property="Stroke" Value="{DynamicResource IG_ScrollBarTrackStrokePointerOver}" />
        <Setter Property="Opacity" Value="1" />
      </Style>
      <!-- Expanded: remove scale transform to show full 6px pill thumb -->
      <Style Selector="^ /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource IG_ScrollBarThumbBackgroundColor}" />
        <Setter Property="RenderTransform" Value="none" />
      </Style>
      <Style Selector="^ /template/ RepeatButton">
        <Setter Property="Opacity" Value="1" />
      </Style>
    </Style>
  </ControlTheme>

</ResourceDictionary>

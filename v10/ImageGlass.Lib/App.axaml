<Application
    x:Class="ImageGlass.Common.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ImageGlass.UI"
    RequestedThemeVariant="Default">
    <!--  "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options.  -->


    <Application.Styles>
        <FluentTheme />


        <!--  Menu Dropdown animation  -->
        <Style Selector="MenuFlyoutPresenter, ContextMenu, ToolTip, Popup">
            <!--  1. Initialize the transform so the animator has something to target  -->
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
            </Setter>

            <Style.Animations>
                <Animation Easing="CubicEaseOut" Duration="0:0:0.15">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.0" />
                        <!--  2. Target the specific properties of the ScaleTransform  -->
                        <Setter Property="ScaleTransform.ScaleX" Value="0.95" />
                        <Setter Property="ScaleTransform.ScaleY" Value="0.95" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0" />
                        <Setter Property="ScaleTransform.ScaleX" Value="1.0" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1.0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>



        <!--  Context Menu shadow  -->
        <Style Selector="MenuFlyoutPresenter > Border, ContextMenu > Border, ToolTip > Border, Popup > Border">
            <Setter Property="Margin" Value="6, 1, 6, 12" />
            <Setter Property="BoxShadow" Value="{DynamicResource MenuShadow}" />
        </Style>



        <!--  Menu separator  -->
        <Style Selector="Separator">
            <Setter Property="Background" Value="{DynamicResource IG_MenuSeparatorBackground}" />
        </Style>



        <!--  Menu item  -->
        <Style Selector="MenuItem">
            <Setter Property="Margin" Value="4, 0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />


            <!--  Menu item content  -->
            <Style Selector="^ /template/ Border#PART_LayoutRoot">
                <Setter Property="Transitions">
                    <Transitions>
                        <BrushTransition Property="Background" Duration="0:0:0.05" />
                        <BrushTransition Property="BorderBrush" Duration="0:0:0.05" />
                    </Transitions>
                </Setter>
            </Style>

            <!--  Fixed: check mark is cut off  -->
            <Style Selector="^:checked:toggle /template/ ContentControl#PART_ToggleIconPresenter Path">
                <Setter Property="Width" Value="14" />
                <Setter Property="Stretch" Value="Uniform" />
            </Style>

            <Style Selector="^:selected /template/ Border#PART_LayoutRoot">
                <Setter Property="BorderBrush" Value="{DynamicResource IG_ToolButtonBackgroundHover}" />
            </Style>
        </Style>



        <!--  ComboBoxItem  -->
        <Style Selector="ComboBoxItem">
            <Setter Property="Margin" Value="4, 0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />

            <Style Selector="^ /template/ PathIcon#DropDownGlyph">
                <Setter Property="Width" Value="10" />
                <Setter Property="Height" Value="10" />
            </Style>
        </Style>



        <!--  Fixed: focus style  -->
        <Style Selector="Button, ToggleButton, CheckBox, RadioButton, TextBox, SelectableTextBlock, ComboBox, ContextMenu, MenuItem">
            <Setter Property="FocusAdorner">
                <FocusAdornerTemplate>
                    <Border
                        BorderBrush="{DynamicResource SystemControlForegroundBaseHighBrush}"
                        BorderThickness="2"
                        CornerRadius="{DynamicResource ControlCornerRadius}">
                        <Border
                            BorderBrush="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource ControlCornerRadius}" />
                    </Border>
                </FocusAdornerTemplate>
            </Setter>
        </Style>


        <!--  Disabled style for buttons  -->
        <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter, ToggleButton:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Opacity" Value="0.5" />
        </Style>

    </Application.Styles>



    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  WinUI 3-style ScrollBar  -->
                <ResourceInclude Source="avares://ImageGlass.Lib/UI/Styles/ScrollBarStyle.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <BoxShadows x:Key="MenuShadow">0 6 12 0 #40000000</BoxShadows>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <BoxShadows x:Key="MenuShadow">0 6 12 0 #60000000</BoxShadows>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>


            <!--  Menu item spacing  -->
            <Thickness x:Key="MenuFlyoutItemThemePaddingNarrow">8,4,8,4</Thickness>
            <Thickness x:Key="MenuInputGestureTextMargin">6,0,0,0</Thickness>
            <Thickness x:Key="MenuIconPresenterMargin">0,0,6,0</Thickness>
            <Thickness x:Key="MenuFlyoutItemChevronMargin">6,0,0,0</Thickness>

            <!--  Combobox  -->
            <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="{DynamicResource SystemAltMediumLowColor}" />
            <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="{DynamicResource SystemAccentColor}" />
            <Thickness x:Key="ComboBoxItemThemePadding">8,3,8,5</Thickness>

            <!--  Tooltip  -->
            <x:Double x:Key="ToolTipContentThemeFontSize">13</x:Double>
            <x:Double x:Key="ToolTipContentMaxWidth">500</x:Double>

            <!--  Text selection color  -->
            <SolidColorBrush
                x:Key="TextControlSelectionHighlightColor"
                Opacity="0.4"
                Color="{DynamicResource SystemAccentColor}" />


            <!--  Icons  -->
            <StreamGeometry x:Key="IconEllipsis">
                M3,12 A1.5,1.5 0 1,1 6,12 A1.5,1.5 0 1,1 3,12 M10,12 A1.5,1.5 0 1,1 13,12 A1.5,1.5 0 1,1 10,12 M17,12 A1.5,1.5 0 1,1 20,12 A1.5,1.5 0 1,1 17,12
            </StreamGeometry>

            <StreamGeometry x:Key="IconClose">M 0,0 L 10,10 M 10,0 L 0,10</StreamGeometry>
            <StreamGeometry x:Key="IconSettings">M12,15.5 A3.5,3.5 0 1 1 12,8.5 A3.5,3.5 0 1 1 12,15.5 M19.43,12.98 C19.47,12.66 19.5,12.34 19.5,12 C19.5,11.66 19.47,11.34 19.43,11.02 L21.54,9.37 C21.73,9.22 21.78,8.95 21.66,8.73 L19.66,5.27 C19.54,5.05 19.27,4.97 19.05,5.05 L16.56,6.05 C16.04,5.65 15.48,5.32 14.87,5.07 L14.49,2.42 C14.46,2.18 14.25,2 14,2 L10,2 C9.75,2 9.54,2.18 9.51,2.42 L9.13,5.07 C8.52,5.32 7.96,5.65 7.44,6.05 L4.95,5.05 C4.73,4.97 4.46,5.05 4.34,5.27 L2.34,8.73 C2.21,8.95 2.27,9.22 2.46,9.37 L4.57,11.02 C4.53,11.34 4.5,11.66 4.5,12 C4.5,12.34 4.53,12.66 4.57,12.98 L2.46,14.63 C2.27,14.78 2.21,15.05 2.34,15.27 L4.34,18.73 C4.46,18.95 4.73,19.03 4.95,18.95 L7.44,17.95 C7.96,18.35 8.52,18.68 9.13,18.93 L9.51,21.58 C9.54,21.82 9.75,22 10,22 L14,22 C14.25,22 14.46,21.82 14.49,21.58 L14.87,18.93 C15.48,18.68 16.04,18.35 16.56,17.95 L19.05,18.95 C19.27,19.03 19.54,18.95 19.66,18.73 L21.66,15.27 C21.78,15.05 21.73,14.78 21.54,14.63 L19.43,12.98 Z</StreamGeometry>


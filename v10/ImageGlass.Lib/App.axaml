            </StreamGeometry>

            <StreamGeometry x:Key="IconSaveAs">
                M17 6.12501V9.03545C16.8367 9.01209 16.6698 9 16.5 9H16V6.12501C16.003 5.99304 15.9789 5.86186 15.9292 5.73958C15.8795 5.61729 15.8052 5.50649 15.711 5.41401L13.586 3.28901C13.4292 3.1302 13.222 3.03086 13 3.00801V5.50001C13.0009 5.69865 12.9611 5.89537 12.883 6.07801C12.8076 6.25614 12.6986 6.41808 12.562 6.55501C12.4222 6.69314 12.2581 6.80433 12.078 6.88301C11.8966 6.96487 11.699 7.00486 11.5 7.00001H7.50001C7.30138 7.00093 7.10466 6.96111 6.92201 6.88301C6.74389 6.80761 6.58194 6.69863 6.44501 6.56201C6.30688 6.42219 6.19569 6.25812 6.11701 6.07801C6.03516 5.89656 5.99517 5.69901 6.00001 5.50001V3.00001H5.00001C4.86569 2.99871 4.73256 3.02527 4.60901 3.07801C4.49272 3.12818 4.38688 3.19975 4.29701 3.28901C4.20532 3.3816 4.13113 3.49002 4.07801 3.60901C4.0216 3.73139 3.99488 3.86535 4.00001 4.00001V14C3.99872 14.1343 4.02528 14.2675 4.07801 14.391C4.12954 14.509 4.20091 14.6172 4.28901 14.711C4.3763 14.8038 4.48325 14.8759 4.60201 14.922C4.72923 14.9706 4.86386 14.997 5.00001 15V10.5C4.99909 10.3014 5.03891 10.1047 5.11701 9.92201C5.19241 9.74388 5.30139 9.58194 5.43801 9.44501C5.57783 9.30688 5.7419 9.19569 5.92201 9.11701C6.10347 9.03515 6.30101 8.99516 6.50001 9.00001H12.4917C11.5414 9.0022 10.6799 9.3832 10.0505 10H6.50001C6.36781 10.0013 6.24139 10.0544 6.1479 10.1479C6.05441 10.2414 6.00132 10.3678 6.00001 10.5V15H9V16H5.00001C4.73927 16.001 4.48116 15.9479 4.24201 15.844C4.00563 15.7419 3.78901 15.599 3.60201 15.422C3.41612 15.2478 3.26717 15.038 3.16401 14.805C3.05836 14.5633 3.00258 14.3028 3.00001 14.039V4.00001C2.999 3.73927 3.05212 3.48116 3.15601 3.24201C3.25794 3.00491 3.40078 2.7876 3.57801 2.60001C3.75389 2.41429 3.96545 2.26599 4.20001 2.16401C4.44016 2.05901 4.69893 2.00324 4.96101 2.00001H12.875C13.1375 1.9992 13.3977 2.04947 13.641 2.14801C13.8854 2.24691 14.1061 2.39615 14.289 2.58601L16.414 4.71101C16.5999 4.89556 16.7462 5.11604 16.844 5.35901C16.9428 5.60255 16.9956 5.86225 17 6.12501ZM7.00001 3.00001V5.50001C7.00132 5.6322
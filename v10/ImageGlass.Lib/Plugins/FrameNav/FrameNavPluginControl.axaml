<ui:PhControl
    x:Class="ImageGlass.Plugins.FrameNavPluginControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ac="using:ImageGlass.Common.Actions"
    xmlns:cm="using:ImageGlass.Common"
    xmlns:ui="using:ImageGlass.UI"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:Name="Root"
    Padding="6,12">

    <Grid ColumnDefinitions="1*,Auto,1*" ColumnSpacing="8">
        <TextBlock
            x:Name="PART_FrameCount"
            Grid.Column="0"
            Margin="0,0,4,0"
            VerticalAlignment="Center"
            Text="{CompiledBinding #Root.FrameTextInfo}"
            TextAlignment="Right" />

        <Border
            Grid.Column="1"
            Padding="6"
            Background="{DynamicResource IG_BackgroundNeutralBrush}"
            CornerRadius="10">
            <StackPanel
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="4">
                <!--  View first frame  -->
                <ui:ToolbarButton
                    x:Name="PART_BtnViewFirstFrame"
                    Focusable="False"
                    IsEnabled="{CompiledBinding #Root.HasMultiFrames}">
                    <PathIcon
                        Width="24"
                        Height="24"
                        Data="{StaticResource IconArrowPrevious}" />
                </ui:ToolbarButton>


                <!--  View previous frame  -->
                <ui:ToolbarButton
                    x:Name="PART_BtnViewPreviousFrame"
                    Focusable="False"
                    IsEnabled="{CompiledBinding #Root.HasMultiFrames}">
                    <PathIcon
                        Width="24"
                        Height="24"
                        Data="{StaticResource IconArrowLeft}" />
                </ui:ToolbarButton>


                <!--  Play/Pause animation  -->
                <ui:ToolbarButton
                    x:Name="PART_BtnToggleAnimation"
                    Focusable="False"
                    IsEnabled="{CompiledBinding #Root.CanPlay}">
                    <StackPanel IsVisible="{CompiledBinding !#Root.IsLivePhoto}" Orientation="Horizontal">
                        <!--  Live Photo  -->
                        <PathIcon
                            Width="24"
                            Height="24"
                            Data="{StaticResource IconLivePhoto}"
                            IsVisible="{CompiledBinding #Root.IsLivePhoto}" />


                        <!--  Animated Photo  -->
                        <StackPanel IsVisible="{CompiledBinding !#Root.IsLivePhoto}">
                            <PathIcon
                                Width="24"
                                Height="24"
                                Data="{StaticResource IconPlay}"
                                IsVisible="{CompiledBinding !#Root.IsPlaying}" />
                            <PathIcon
                                Width="24"
                                Height="24"
                                Data="{StaticResource IconPause}"
                                IsVisible="{CompiledBinding #Root.IsPlaying}" />
                        </StackPanel>
                    </StackPanel>
                </ui:ToolbarButton>


                <!--  View next frame  -->
                <ui:ToolbarButton
                    x:Name="PART_BtnViewNextFrame"
                    Focusable="False"
                    IsEnabled="{CompiledBinding #Root.HasMultiFrames}">
                    <PathIcon
                        Width="24"
                        Height="24"
                        Data="{StaticResource IconArrowRight}" />
                </ui:ToolbarButton>


                <!--  View last frame  -->
                <ui:ToolbarButton
                    x:Name="PART_BtnViewLastFrame"
                    Focusable="False"
                    IsEnabled="{CompiledBinding #Root.HasMultiFrames}">
                    <PathIcon
                        Width="24"
                        Height="24"
                        Data="{StaticResource IconArrowNext}" />
                </ui:ToolbarButton>
            </StackPanel>
        </Border>


        <StackPanel
            Grid.Column="2"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <!--  Export current frame  -->
            <ui:ToolbarButton
                x:Name="PART_BtnExportFrame"
                Focusable="False"
                IsEnabled="{CompiledBinding #Root.HasMultiFrames}">
                <PathIcon
                    Width="24"
                    Height="24"
                    Data="{StaticResource IconImageForward}" />
            </ui:ToolbarButton>
        </StackPanel>

    </Grid>
</ui:PhControl>

<?xml version="1.0" encoding="utf-8" ?>
<ui:IgControl
    x:Class="ImageGlass.MainWindow_Content"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="using:ImageGlass.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:ImageGlass.UI"
    d:DataContext="{d:DesignInstance Type=local:MainWindow_Content}"
    x:DefaultBindMode="OneWay"
    IsTabStop="False"
    mc:Ignorable="d">

    <ui:IgControl.Resources>

        <MenuFlyout x:Key="RES_MainMenu" x:Name="PART_MainMenu">

            <!--  File  -->
            <MenuFlyoutSubItem x:Name="MnuFile" Text="[File]">
                <MenuFlyoutItem x:Name="MnuOpenFile" Text="[Open file...]" />
                <MenuFlyoutItem x:Name="MnuNewWindow" Text="[Open new window]" />
                <MenuFlyoutItem x:Name="MnuSave" Text="[Save]" />
                <MenuFlyoutItem x:Name="MnuSaveAs" Text="[Save as...]" />
                <MenuFlyoutSeparator />

                <MenuFlyoutItem x:Name="MnuOpenWith" Text="[Open with...]" />
                <MenuFlyoutItem x:Name="MnuEdit" Text="[Edit image]" />
                <MenuFlyoutItem x:Name="MnuPrint" Text="[Print...]" />
                <MenuFlyoutItem x:Name="MnuShare" Text="[Share...]" />
                <MenuFlyoutSeparator />

                <MenuFlyoutItem x:Name="MnuRefresh" Text="[Refresh]" />
                <MenuFlyoutItem x:Name="MnuReload" Text="[Reload image]" />
                <MenuFlyoutItem x:Name="MnuReloadImageList" Text="[Reload list]" />
                <MenuFlyoutItem x:Name="MnuUnload" Text="[Unload]" />
            </MenuFlyoutSubItem>


            <!--  Navigation  -->
            <MenuFlyoutSubItem x:Name="MnuNavigation" Text="[Navigation]">
                <MenuFlyoutItem Text="[Save]" />
                <MenuFlyoutSeparator />
            </MenuFlyoutSubItem>


            <!--  Zoom  -->
            <MenuFlyoutSubItem Text="[Zoom]">
                <MenuFlyoutItem Text="[Save]" />
                <MenuFlyoutSeparator />
            </MenuFlyoutSubItem>

            <!--  Panning  -->
            <MenuFlyoutSubItem Text="[Panning]">
                <MenuFlyoutItem Text="[Save]" />
                <MenuFlyoutSeparator />
            </MenuFlyoutSubItem>


            <!--  Image  -->
            <MenuFlyoutSubItem Text="[Image]">
                <MenuFlyoutItem Text="[Save]" />
                <MenuFlyoutSeparator />
            </MenuFlyoutSubItem>


            <!--  Clipboard  -->
            <MenuFlyoutSubItem Text="[Clipboard]">
                <MenuFlyoutItem Text="[Save]" />
                <MenuFlyoutSeparator />
            </MenuFlyoutSubItem>


            <!--  Window modes  -->
            <MenuFlyoutSeparator />
            <ToggleMenuFlyoutItem Text="[WindowFit]" />
            <ToggleMenuFlyoutItem IsChecked="True" Text="[Frameless]" />
            <ToggleMenuFlyoutItem Text="[Fullscreen]" />
            <ToggleMenuFlyoutItem Text="[Slideshow]" />
            <MenuFlyoutSeparator />


            <!--  Layout  -->
            <MenuFlyoutSubItem Text="[Layout]">
                <MenuFlyoutItem Text="[Save]" />
                <MenuFlyoutSeparator />
            </MenuFlyoutSubItem>


            <!--  Tools  -->
            <MenuFlyoutSubItem Text="[Tools]">
                <MenuFlyoutItem Text="[Save]" />
                <MenuFlyoutSeparator />
            </MenuFlyoutSubItem>


            <!--  Settings  -->
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="[Settings]" />


            <!--  Help  -->
            <MenuFlyoutSubItem Text="[Help]">
                <MenuFlyoutItem Text="[About]" />
                <MenuFlyoutItem Text="[Check for update]" />
                <MenuFlyoutItem Text="[Report an issue]" />
                <MenuFlyoutItem Text="[Open ImageGlass Quick Setup]" />
                <MenuFlyoutSeparator />
            </MenuFlyoutSubItem>


            <!--  Exit  -->
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="[Exit]">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Escape" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
        </MenuFlyout>

    </ui:IgControl.Resources>



    <Grid IsTabStop="True" TabFocusNavigation="Local">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <!--  Toolbar  -->
        <ui:ToolbarControl
            x:Name="PART_ToolbarMain"
            Grid.Row="0"
            Canvas.ZIndex="90"
            IsTabStop="False"
            ItemsSource="{x:Bind cm:AP.Config.ToolbarButtons}"
            MainMenu="{StaticResource RES_MainMenu}" />


        <!--  Viewer  -->
        <ui:VirtualViewerControl
            x:Name="PART_Viewer"
            Grid.Row="1"
            AllowDrop="True"
            BackgroundColor="{x:Bind cm:AP.Config.Theme.ComputedColors.BgColor}"
            CheckerboardMode="{x:Bind cm:AP.Config.CheckerboardMode}"
            EnableDebug="{x:Bind cm:AP.Config.EnableDebug}"
            IsTabStop="False"
            PanSpeed="{x:Bind cm:AP.Config.PanSpeed}"
            ZoomLevels="{x:Bind cm:AP.Config.ZoomLevels}"
            ZoomMode="{x:Bind cm:AP.Config.ZoomMode}"
            ZoomSpeed="{x:Bind cm:AP.Config.ZoomSpeed}">

            <!--  Viewer In-App Message  -->
            <Grid
                x:Name="PART_ViewerMessage"
                MaxWidth="1200"
                Margin="20"
                Padding="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="8"
                Visibility="{x:Bind IsMessageVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    VerticalAlignment="Top"
                    Orientation="Vertical"
                    Spacing="12">
                    <!--  Heading  -->
                    <Border Visibility="{x:Bind MessageHeading, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock
                            FontSize="18"
                            Foreground="{ThemeResource AccentTextFillColorTertiaryBrush}"
                            HorizontalTextAlignment="Center"
                            IsColorFontEnabled="True"
                            Text="{x:Bind MessageHeading}"
                            TextWrapping="WrapWholeWords" />
                    </Border>

                    <!--  Description  -->
                    <Border Visibility="{x:Bind MessageDescription, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock
                            FontSize="12"
                            Foreground="{x:Bind cm:AP.Config.Theme.ComputedColors.TextColor, Converter={StaticResource ColorToBrushConverter}}"
                            HorizontalTextAlignment="Center"
                            IsColorFontEnabled="True"
                            Text="{x:Bind MessageDescription}"
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>

                <!--  Details  -->
                <ScrollViewer
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="5"
                    BorderBrush="{x:Bind cm:AP.Config.Theme.ComputedColors.TextColor, Converter={StaticResource ColorToBrushConverter}}"
                    BorderThickness="1"
                    CornerRadius="6"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Auto"
                    Visibility="{x:Bind MessageDetails, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock
                        FontFamily="Cascadia Mono, Consolas"
                        FontSize="12"
                        FontWeight="SemiLight"
                        Foreground="{x:Bind cm:AP.Config.Theme.ComputedColors.TextColor, Converter={StaticResource ColorToBrushConverter}}"
                        IsColorFontEnabled="True"
                        Text="{x:Bind MessageDetails}"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>


        </ui:VirtualViewerControl>


        <!--  Gallery  -->
        <ui:GalleryControl
            x:Name="PART_Gallery"
            Grid.Row="2"
            Grid.Column="1"
            Canvas.ZIndex="80"
            IsTabStop="False"
            VM="{x:Bind cm:AP.Photos, Mode=OneWay}" />

    </Grid>


</ui:IgControl>

<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="ImageGlass.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ImageGlass">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!--  Other merged dictionaries here  -->
            </ResourceDictionary.MergedDictionaries>
            <!--  Other app resources here  -->


            <SolidColorBrush
                x:Key="ItemBorderSelected"
                Opacity="0.5"
                Color="{ThemeResource SystemAccentColor}" />
            <SolidColorBrush
                x:Key="ItemBackgroundHovered"
                Opacity="0.2"
                Color="{ThemeResource SystemAccentColor}" />
            <SolidColorBrush
                x:Key="ItemBackgroundPressed"
                Opacity="0.35"
                Color="{ThemeResource SystemAccentColor}" />
            <SolidColorBrush
                x:Key="ItemBackgroundSelected"
                Opacity="0.3"
                Color="{ThemeResource SystemAccentColor}" />


            <!--  Gallery  -->
            <x:Double x:Key="GalleryThumbnailSize">70</x:Double>



        </ResourceDictionary>
    </Application.Resources>
</Application>

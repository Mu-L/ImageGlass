<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ImageGlass.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winNT="using:ImageGlass.WinNT"
    Title="ImageGlass"
    Closed="Window_Closed"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>


    <Grid x:Name="ContentArea">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <Grid
            x:Name="WinMainTitleBar"
            Grid.Row="0"
            Height="{x:Bind TitleBarHeight.Value}"
            Padding="{x:Bind TitleBarMargin}"
            Canvas.ZIndex="100">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>


            <ImageIcon
                Grid.Column="0"
                Width="20"
                Margin="5,0,5,0"
                Source="/Assets/Square44x44Logo.png" />

            <TextBlock
                x:Name="WinMainTitleBarText"
                Grid.Column="1"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind Title}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
        </Grid>


        <!--  Toolbar  -->
        <Grid
            Grid.Row="1"
            VerticalAlignment="Top"
            Canvas.ZIndex="99">

            <StackPanel
                Padding="5"
                HorizontalAlignment="Right"
                Orientation="Horizontal">

                <Button Margin="1" Click="BtnOpenFile_Clicked">Open File</Button>
                <Button Margin="1" Click="BtnOpenFolder_Clicked">Open Folder</Button>

                <Button Margin="50,1,1,1" Click="BtnViewPrevious_Clicked">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Left" />
                    </Button.KeyboardAccelerators>
                    View Previous
                </Button>
                <Button Margin="1" Click="BtnViewNext_Clicked">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Right" />
                    </Button.KeyboardAccelerators>
                    View Next
                </Button>
            </StackPanel>
        </Grid>


        <!--  Gallery  -->
        <Grid
            Grid.Row="3"
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Canvas.ZIndex="98">
            <winNT:GalleryControl
                x:Name="Gallery"
                ItemClicked="Gallery_ItemClicked"
                PhotoManager="{x:Bind local:Local.Photos, Mode=OneWay}" />
        </Grid>


        <!--  Viewer  -->
        <Grid Grid.Row="2">
            <Border BorderBrush="Red" BorderThickness="0">
                <winNT:VirtualViewerControl
                    x:Name="Viewer"
                    BackgroundColor="#22000000"
                    EnableDebug="False"
                    EnableSelection="False"
                    Loaded="Viewer_Loaded" />
            </Border>
        </Grid>

    </Grid>

</Window>

<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ImageGlass.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winNT="using:ImageGlass.WinNT"
    Title="ImageGlass"
    Closed="Window_Closed"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>


    <Grid x:Name="ContentArea">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <Grid
            x:Name="WinMainTitleBar"
            Grid.Row="0"
            Height="{x:Bind TitleBarHeight.Value}"
            Padding="{x:Bind TitleBarMargin}"
            Background="#20ff"
            Canvas.ZIndex="100">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>


            <ImageIcon
                Grid.Column="0"
                Width="20"
                Margin="5,0,5,0"
                Source="/Assets/Square44x44Logo.png" />

            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind Title}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
        </Grid>


        <!--  Toolbar  -->
        <Grid
            Grid.Row="1"
            VerticalAlignment="Top"
            Background="#20ff"
            Canvas.ZIndex="99">

            <Button Click="Button_Click">Open</Button>
        </Grid>


        <!--  Gallery  -->
        <Grid
            Grid.Row="3"
            Height="100"
            VerticalAlignment="Bottom"
            Background="#20ff"
            Canvas.ZIndex="98" />


        <!--  Viewer  -->
        <Grid Grid.Row="2">
            <Border BorderBrush="Red" BorderThickness="0">
                <winNT:VirtualViewerControl
                    x:Name="Viewer"
                    EnableDebug="True"
                    EnableSelection="True"
                    Loaded="Viewer_Loaded" />
            </Border>
        </Grid>

    </Grid>

</Window>

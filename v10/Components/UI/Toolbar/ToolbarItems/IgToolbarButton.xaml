<?xml version="1.0" encoding="utf-8" ?>
<local:IgToolbarItem
    x:Class="ImageGlass.UI.IgToolbarButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="using:ImageGlass.Common"
    xmlns:common="using:ImageGlass.Common"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DefaultBindMode="OneWay"
    AutomationProperties.AutomationControlType="Button"
    DataContext="{x:Bind VM, Mode=OneWay}"
    IsTabStop="False"
    mc:Ignorable="d">

    <local:IgButton
        Name="PART_Button"
        Padding="{x:Bind local:IgToolbarButton.ItemPadding}"
        x:DefaultBindMode="OneWay"
        AutomationProperties.Name="{x:Bind VM.DisplayText}"
        Click="PART_Button_Click"
        Flyout="{x:Bind Flyout}"
        Id="{x:Bind VM.Id}"
        IsChecked="{x:Bind VM.IsChecked}"
        IsToggle="{x:Bind VM.IsToggle}"
        Style="{StaticResource IgButtonStyle}"
        Text="{x:Bind VM.DisplayText}"
        ToolTipService.ToolTip="{x:Bind VM.DisplayText}">
        <StackPanel Orientation="Horizontal" Spacing="{x:Bind local:IgToolbarButton.InnerSpacing}">
            <ImageIcon
                Name="PART_ButtonIcon"
                Width="{x:Bind cm:AP.Config.ToolbarIconHeight}"
                Height="{x:Bind cm:AP.Config.ToolbarIconHeight}" />

            <TextBlock
                Name="PART_ButtonText"
                VerticalAlignment="Center"
                Foreground="{x:Bind cm:AP.Config.Theme.ComputedColors.ToolbarTextColor, Converter={StaticResource ColorToBrushConverter}}"
                IsColorFontEnabled="True"
                Text="{x:Bind VM.DisplayText}"
                Visibility="{x:Bind VM.IsTextVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
    </local:IgButton>

</local:IgToolbarItem>

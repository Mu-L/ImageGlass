<?xml version="1.0" encoding="utf-8" ?>
<local:IgControl
    x:Class="ImageGlass.UI.ToolbarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="using:ImageGlass.Common"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    d:DataContext="{d:DesignInstance local:ToolbarControl,
                                     IsDesignTimeCreatable=True}"
    x:DefaultBindMode="OneWay"
    AutomationProperties.AutomationControlType="ToolBar"
    IsTabStop="False"
    mc:Ignorable="d">

    <local:IgControl.Resources>

        <!--  ToolbarItemTemplate  -->
        <DataTemplate
            x:Key="ToolbarItemTemplate"
            x:DataType="cm:ToolbarItemModel"
            x:DefaultBindMode="OneWay">

            <ctk:SwitchPresenter
                TargetType="x:Boolean"
                Visibility="{x:Bind IsOverflow, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}"
                Value="{x:Bind IsSeparator}">
                <!--  Separator  -->
                <ctk:Case Value="True">
                    <local:IgToolbarSeparator
                        Name="PART_ItemSeparator"
                        IsTabStop="False"
                        Loaded="ToolbarItem_Loaded"
                        VM="{x:Bind}" />
                </ctk:Case>

                <!--  Button  -->
                <ctk:Case IsDefault="True">
                    <local:IgToolbarButton
                        Name="PART_ItemButton"
                        Clicked="PART_ItemButton_Clicked"
                        IsTabStop="False"
                        Loaded="ToolbarItem_Loaded"
                        VM="{x:Bind}" />
                </ctk:Case>
            </ctk:SwitchPresenter>

        </DataTemplate>
    </local:IgControl.Resources>



    <Grid
        x:Name="GridToolbar"
        Padding="{x:Bind local:IgToolbarButton.ItemPadding}"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Background="{x:Bind cm:AP.Config.Theme.Colors.ToolbarBgColor, Converter={StaticResource HexStringToBrushConverter}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>


        <!--  Toolbar: Primary Items  -->
        <StackPanel
            x:Name="PanelPrimary"
            Grid.Column="0"
            HorizontalAlignment="Center">
            <ItemsRepeater
                x:Name="RepeaterPrimaryItems"
                ItemTemplate="{StaticResource ToolbarItemTemplate}"
                ItemsSource="{x:Bind PrimaryItems}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" Spacing="{x:Bind local:ToolbarControl.ItemSpacing, Mode=OneTime}" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </StackPanel>


        <!--  Right Column  -->
        <StackPanel
            x:Name="PanelRight"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Canvas.ZIndex="90"
            Orientation="Horizontal"
            Spacing="{x:Bind local:ToolbarControl.ItemSpacing, Mode=OneTime}">


            <!--  Toolbar: Overflow button  -->
            <local:IgButton
                x:Name="BtnOverflowMenu"
                Padding="{x:Bind local:IgToolbarButton.ItemPadding}"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Bottom"
                Style="{StaticResource IgButtonStyle}"
                ToolTipService.ToolTip="{x:Bind cm:AP.Config.Lang.Get(cm:LangId.FrmMain_MnuToolbarOverflow)}"
                Visibility="Collapsed">
                <StackPanel VerticalAlignment="Stretch" Orientation="Horizontal">
                    <Viewbox
                        Width="{x:Bind cm:AP.Config.ToolbarIconHeight}"
                        Height="{x:Bind local:ToolbarControl.OverflowIconHeight}"
                        VerticalAlignment="Bottom">
                        <FontIcon
                            AutomationProperties.AccessibilityView="Raw"
                            Foreground="{x:Bind cm:AP.Config.Theme.ComputedColors.ToolbarTextColor, Converter={StaticResource ColorToBrushConverter}}"
                            Glyph="&#xE712;" />
                    </Viewbox>
                </StackPanel>

                <local:IgButton.Flyout>
                    <MenuFlyout
                        x:Name="MnuOverflow"
                        Opening="MnuOverflow_Opening"
                        Placement="BottomEdgeAlignedRight" />
                </local:IgButton.Flyout>
            </local:IgButton>


            <!--  Toolbar: Secondary Items  -->
            <ItemsRepeater
                x:Name="RepeaterSecondaryItems"
                Grid.Column="0"
                HorizontalAlignment="Center"
                ItemTemplate="{StaticResource ToolbarItemTemplate}"
                ItemsSource="{x:Bind SecondaryItems}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" Spacing="{x:Bind local:ToolbarControl.ItemSpacing, Mode=OneTime}" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>


            <!--  Menu button  -->
            <local:IgToolbarButton
                x:Name="BtnMainMenu"
                Flyout="{x:Bind MainMenu}"
                IsTabStop="False"
                OpenFlyoutOnClick="True" />


        </StackPanel>

    </Grid>


</local:IgControl>

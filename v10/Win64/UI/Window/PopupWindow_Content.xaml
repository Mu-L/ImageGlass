<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ImageGlass.Win64.UI.PopupWindow_Content"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.Win64.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance local:PopupWindow_Content,
                                     IsDesignTimeCreatable=True}"
    x:DefaultBindMode="OneWay"
    mc:Ignorable="d">


    <StackPanel
        Grid.Row="1"
        Padding="24,12,24,24"
        VerticalAlignment="Top"
        Background="{StaticResource CardBackgroundFillColorDefault}"
        Spacing="24">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>


            <Grid
                Width="80"
                Height="80"
                Margin="0,8,16,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Visibility="{x:Bind VM.IsThumbnailSectionVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                <!--  Thumbnail  -->
                <Viewbox
                    MaxWidth="80"
                    MaxHeight="80"
                    Stretch="Uniform"
                    Visibility="{x:Bind VM.Thumbnail, Converter={StaticResource NullableToVisibilityConverter}}">
                    <Image
                        x:Name="PART_Thumbnail"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="/Assets/StoreLogo.png" />
                </Viewbox>

                <!--  ThumbnailIcon  -->
                <Image
                    x:Name="PART_ThumbnailIcon"
                    Width="32"
                    Height="32"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Source="/Assets/icon256.ico"
                    Visibility="{x:Bind VM.ThumbnailIcon, Converter={StaticResource NullableToVisibilityConverter}}" />
            </Grid>


            <StackPanel
                Grid.Column="1"
                Orientation="Vertical"
                Spacing="16">

                <!--  Heading  -->
                <TextBlock
                    x:Name="PART_Heading"
                    IsTextSelectionEnabled="True"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="{x:Bind VM.Heading}"
                    TextWrapping="WrapWholeWords"
                    Visibility="{x:Bind VM.Heading, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Description  -->
                <TextBlock
                    x:Name="PART_Description"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind VM.Description}"
                    TextWrapping="WrapWholeWords"
                    Visibility="{x:Bind VM.Description, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Input  -->
                <TextBox x:Name="PART_Input" Visibility="{x:Bind VM.IsInputVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!--  Details  -->
                <TextBox
                    x:Name="PART_Details"
                    MaxHeight="150"
                    AcceptsReturn="True"
                    FontFamily="Cascadia Mono, Consolas"
                    FontSize="13"
                    FontWeight="SemiLight"
                    IsReadOnly="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollMode="Enabled"
                    Text="{x:Bind VM.Details}"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind VM.Details, Converter={StaticResource StringToVisibilityConverter}}" />

            </StackPanel>
        </Grid>


        <StackPanel Spacing="12">
            <!--  Note  -->
            <Border
                Padding="8"
                Background="{StaticResource SystemFillColorCautionBackgroundBrush}"
                CornerRadius="4"
                Visibility="{x:Bind VM.Note, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock
                    x:Name="PART_Note"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind VM.Note}"
                    TextWrapping="WrapWholeWords" />
            </Border>

            <!--  RememberOption  -->
            <CheckBox x:Name="PART_Checkbox" Visibility="{x:Bind VM.IsRememberOptionVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{x:Bind VM.RememberOptionText}" />
            </CheckBox>

        </StackPanel>
    </StackPanel>

</UserControl>

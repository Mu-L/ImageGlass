<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ImageGlass.Win64.UI.DialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.Win64.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:w64c="using:ImageGlass.Win64.Common"
    Title="{x:Bind _winHook.Title}"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>


    <local:DialogContent
        x:Name="Root"
        MaxWidth="600"
        MaxHeight="600"
        Button1Click="PART_Dialog_BtnAccept_Click"
        Button2Click="PART_Dialog_BtnCancel_Click"
        Button3Click="PART_Dialog_BtnApply_Click"
        KeyboardAcceleratorPlacementMode="Hidden">
        <StackPanel
            Grid.Row="1"
            Padding="24,12,24,24"
            VerticalAlignment="Top"
            Background="{StaticResource CardBackgroundFillColorDefault}"
            Spacing="24">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid
                    Width="80"
                    Height="80"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
                    <Viewbox
                        MaxWidth="80"
                        MaxHeight="80"
                        Stretch="Uniform">
                        <Image
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="/Assets/StoreLogo.png" />
                    </Viewbox>
                    <Image
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Source="/Assets/icon256.ico" />
                </Grid>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Vertical"
                    Spacing="16">
                    <TextBlock
                        Name="PART_Dialog_Heading"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="Pellentesque pellentesque nibh a orci feugiat, ut imperdiet risus sodales"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Name="PART_Dialog_Description"
                        Text="Duis semper eros in elit placerat placerat. Cras vehicula, erat vitae auctor dignissim, risus metus pharetra odio, itae auctor dignissim, risus metus pharetra odio vitae elemen."
                        TextWrapping="WrapWholeWords" />

                    <TextBox
                        Name="PART_Dialog_Textbox"
                        MaxHeight="100"
                        AcceptsReturn="True"
                        FontFamily="Cascadia Mono, Consolas"
                        FontSize="13"
                        FontWeight="SemiLight"
                        IsReadOnly="True"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollMode="Enabled"
                        Text="Nullam hendrerit hendrerit justo vitae ullamcorper. Nam et ante mollis, mollis nulla vel, consequat augue. Donec porttitor lectus vel convallis viverra. Sed in bibendum augue. Maecenas vulputate eget odio quis faucibus. Donec suscipit vitae dolor et volutpat. Ut lobortis odio sed accumsan porta. Sed a arcu vitae est lacinia porta. Proin quis nisi ut magna condimentum ullamcorper sed ac quam. Aliquam et lacus fringilla velit scelerisque luctus. Nulla vehicula, justo sit amet rutrum efficitur, lectus mauris consequat enim, ac vehicula magna urna quis neque."
                        TextWrapping="Wrap" />

                </StackPanel>
            </Grid>


            <StackPanel Spacing="12">
                <Border
                    Padding="8"
                    Background="{StaticResource SystemFillColorCautionBackgroundBrush}"
                    CornerRadius="4">
                    <TextBlock
                        Name="PART_Dialog_Note"
                        Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aenean vitae hendrerit ex."
                        TextWrapping="WrapWholeWords" />
                </Border>

                <CheckBox Name="PART_Dialog_Checkbox" Content="Quisque et orci tincidunt, vestibulum purus." />
            </StackPanel>
        </StackPanel>
    </local:DialogContent>

</Window>

<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ImageGlass.Win64.UI.DialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.Win64.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:w64c="using:ImageGlass.Win64.Common"
    Title="{x:Bind TitlebarText}"
    x:DefaultBindMode="OneWay"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>


    <Grid
        x:Name="Root"
        Height="Auto"
        MaxWidth="600"
        HorizontalAlignment="Left"
        VerticalAlignment="Stretch"
        BackgroundSizing="InnerBorderEdge"
        KeyboardAcceleratorPlacementMode="Hidden"
        SizeChanged="Root_SizeChanged"
        TabFocusNavigation="Cycle">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <!--  Titlebar  -->
        <local:TitlebarControl
            x:Name="PART_Titlebar"
            Grid.Row="0"
            Padding="{x:Bind _winHook.TitleBarPadding}"
            BackgroundColor="{x:Bind w64c:AP.Config.Theme.ComputedColors.ToolbarBgColor}"
            Canvas.ZIndex="100"
            Text="{x:Bind TitlebarText}"
            TextColor="{x:Bind w64c:AP.Config.Theme.ComputedColors.ToolbarTextColor}" />


        <!--  DialogContent  -->
        <Grid Grid.Row="1">
            <ContentPresenter x:Name="PART_DialogContent" Content="{x:Bind DialogContent}" />
        </Grid>


        <!--  Footer  -->
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            Background="{x:Bind FooterBackground}">

            <StackPanel
                Padding="24"
                HorizontalAlignment="Right"
                KeyDown="FooterButtonsPanel_KeyDown"
                Orientation="Horizontal"
                Spacing="8"
                TabFocusNavigation="Once">

                <Button
                    Name="PART_Button1"
                    Grid.Column="0"
                    MinWidth="80"
                    Click="PART_Dialog_Button1_Click"
                    Content="{x:Bind Button1Text}"
                    Visibility="{x:Bind Button1Visibility}" />
                <Button
                    Name="PART_Button2"
                    Grid.Column="1"
                    MinWidth="80"
                    Click="PART_Dialog_Button2_Click"
                    Content="{x:Bind Button2Text}"
                    Visibility="{x:Bind Button2Visibility}" />
                <Button
                    Name="PART_Button3"
                    Grid.Column="2"
                    MinWidth="80"
                    Click="PART_Dialog_Button3_Click"
                    Content="{x:Bind Button3Text}"
                    Visibility="{x:Bind Button3Visibility}" />
            </StackPanel>
        </StackPanel>
    </Grid>

</Window>

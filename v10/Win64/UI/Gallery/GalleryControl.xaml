<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ImageGlass.Win64.UI.GalleryControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.Win64.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:photoing="using:ImageGlass.Win64.Common.Photoing"
    xmlns:photoing1="using:ImageGlass.Common.Photoing"
    x:Name="Root"
    d:DataContext="{d:DesignInstance local:GalleryControl,
                                     IsDesignTimeCreatable=True}"
    x:DefaultBindMode="OneWay"
    SizeChanged="UserControl_SizeChanged"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:SelectionToBackgroundConverter x:Key="SelectionToBackgroundConverter" />
        <local:SelectionToBorderConverter x:Key="SelectionToBorderConverter" />


        <!--  Gallery Item: Template  -->
        <DataTemplate
            x:Key="GalleryItemTemplate"
            x:DataType="photoing:Photo"
            x:DefaultBindMode="OneWay">
            <local:IgGalleryItem
                Width="{StaticResource GalleryThumbnailSize}"
                Height="{StaticResource GalleryThumbnailSize}"
                Padding="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                BorderThickness="1.25"
                Click="GalleryItem_Clicked"
                IsChecked="{x:Bind IsCurrent}"
                IsTabStop="False"
                Style="{StaticResource IgButtonStyle}"
                Theme="{x:Bind local:GalleryControl.IG_AppTheme}"
                VM="{x:Bind}">

                <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Gallery Item: Thumbnail  -->
                    <SymbolIcon Symbol="Page2" Visibility="{x:Bind IsGalleryThumbnailLoading}" />
                    <Image
                        Name="GalleryItem_Thumbnail"
                        Grid.Row="0"
                        Source="{x:Bind GalleryThumbnail}"
                        Stretch="Uniform"
                        Visibility="{x:Bind IsGalleryThumbnailLoaded}" />


                    <!--  Gallery Item: Title  -->
                    <Grid
                        Grid.Row="1"
                        Padding="2,0,2,0"
                        HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Name="GalleryItem_FileName"
                            Grid.Column="0"
                            Text="{x:Bind GalleryFileTitle}"
                            TextTrimming="CharacterEllipsis" />

                        <TextBlock
                            Name="GalleryItem_FileExtension"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Text="{x:Bind GalleryFileExtension}"
                            Visibility="Visible" />
                    </Grid>
                </Grid>
            </local:IgGalleryItem>
        </DataTemplate>

    </UserControl.Resources>



    <ScrollViewer
        x:Name="GalleryScrollViewer"
        Padding="5"
        Background="{x:Bind Theme.ColorBrushes.GalleryBgColor, Converter={StaticResource HexStringToBrushConverter}}"
        HorizontalScrollBarVisibility="Auto"
        HorizontalScrollMode="Enabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Disabled">
        <ItemsRepeater
            x:Name="GalleryItemRepeater"
            HorizontalAlignment="Center"
            ElementClearing="GalleryItemRepeater_ElementClearing"
            ElementPrepared="GalleryItemRepeater_ElementPrepared"
            ItemTemplate="{StaticResource GalleryItemTemplate}"
            ItemsSource="{x:Bind VM.Items}">
            <ItemsRepeater.Layout>
                <StackLayout Orientation="Horizontal" Spacing="{x:Bind local:GalleryControl.ItemSpacing, Mode=OneTime}" />
            </ItemsRepeater.Layout>
        </ItemsRepeater>
    </ScrollViewer>

</UserControl>

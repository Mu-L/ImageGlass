<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ImageGlass.Win64.UI.IgToolbarItemButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="using:ImageGlass.Common"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.Win64.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    DataContext="{x:Bind ViewModel, Mode=OneWay}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:SvgPathToImageSourceConverter x:Key="SvgPathToImageSourceConverter" />
    </UserControl.Resources>


    <local:IgButton
        x:Name="BtnActivator"
        Padding="5"
        Id="{x:Bind ViewModel.Id}"
        IsCheckOnClick="{x:Bind ViewModel.IsToggle}"
        IsChecked="{x:Bind ViewModel.IsToggle}"
        Style="{StaticResource IgButtonStyle}"
        Text="{x:Bind ViewModel.Text}"
        Theme="{x:Bind Theme}"
        ToolTipService.ToolTip="{x:Bind ViewModel.Text}">
        <StackPanel Orientation="Horizontal" Spacing="5">
            <Viewbox
                Width="{StaticResource ToolbarIconSize}"
                Height="{StaticResource ToolbarIconSize}"
                VerticalAlignment="Center">
                <ImageIcon Name="ToolbarItem_Button_Icon" Source="{x:Bind ViewModel.Image, Converter={StaticResource SvgPathToImageSourceConverter}}" />
            </Viewbox>

            <TextBlock
                Name="ToolbarItem_Button_Text"
                VerticalAlignment="Center"
                Text="{x:Bind ViewModel.Text}"
                Visibility="{x:Bind ViewModel.IsTextVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
    </local:IgButton>

</UserControl>

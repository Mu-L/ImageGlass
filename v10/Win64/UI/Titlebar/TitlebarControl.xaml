<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ImageGlass.Win64.UI.TitlebarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.Win64.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:w64c="using:ImageGlass.Win64.Common"
    x:DefaultBindMode="OneWay"
    mc:Ignorable="d">

    <Grid
        Height="31"
        Padding="{x:Bind Padding}"
        Background="{x:Bind BackgroundColor, Converter={StaticResource ColorToBrushConverter}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>


        <ImageIcon
            Name="PART_TitleBar_Icon"
            Grid.Column="0"
            Width="20"
            Height="20"
            Margin="5,0,0,0"
            VerticalAlignment="Center"
            Source="/Assets/icon256.ico"
            Visibility="{x:Bind w64c:AP.Config.ShowAppIcon}" />


        <TextBlock
            Name="PART_TitleBar_Text"
            Grid.Column="1"
            Margin="5,0,0,0"
            VerticalAlignment="Center"
            Foreground="{x:Bind TextColor, Converter={StaticResource ColorToBrushConverter}}"
            IsColorFontEnabled="True"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{x:Bind Text}"
            TextTrimming="CharacterEllipsis"
            TextWrapping="NoWrap" />
    </Grid>

</UserControl>

<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ImageGlass.Win64.UI.IgTextBox_Description"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.Win64.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DefaultBindMode="OneWay"
    mc:Ignorable="d">

    <Grid>
        <!--  Error Icon  -->
        <Border
            x:Name="PART_ErrorIconBorder"
            Margin="0,-22,10,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            CornerRadius="100"
            IsHitTestVisible="False"
            Visibility="{x:Bind IsErrorIconVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <FontIcon
                FontSize="14"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Glyph="&#xEB90;" />

            <Border.Resources>
                <Storyboard x:Name="PART_ErrorIconStoryboard">
                    <DoubleAnimation
                        x:Name="Ani_Opacity"
                        AutoReverse="True"
                        Storyboard.TargetName="PART_ErrorIconBorder"
                        Storyboard.TargetProperty="Opacity"
                        From="1.0"
                        To="0.0" />
                </Storyboard>
            </Border.Resources>
        </Border>


        <!--  Message  -->
        <TextBlock
            Margin="0,4,0,0"
            FontSize="12"
            Foreground="{x:Bind MessageTextBrush}"
            IsColorFontEnabled="True"
            IsTextSelectionEnabled="True"
            Text="{x:Bind Message}"
            TextTrimming="WordEllipsis"
            TextWrapping="NoWrap"
            Visibility="{x:Bind Message, Converter={StaticResource StringToVisibilityConverter}}" />

    </Grid>
</UserControl>

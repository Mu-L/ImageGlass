<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ImageGlass.Win64.UI"
    xmlns:w64c="using:ImageGlass.Win64.Common">


    <!--  Style: DialogContent  -->
    <Style TargetType="local:DialogContent">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:DialogContent">

                    <Grid
                        Name="PART_Root"
                        Height="Auto"
                        MaxWidth="{TemplateBinding MaxWidth}"
                        MaxHeight="{TemplateBinding MaxHeight}"
                        VerticalAlignment="Top"
                        Background="{TemplateBinding Background}"
                        BackgroundSizing="InnerBorderEdge"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        KeyboardAcceleratorPlacementMode="Hidden"
                        RequestedTheme="{TemplateBinding RequestedTheme}"
                        TabFocusNavigation="Cycle">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>


                        <!--  Title bar  -->
                        <local:TitlebarControl
                            Name="PART_Titlebar"
                            Grid.Row="0"
                            Canvas.ZIndex="100" />


                        <!--  Content  -->
                        <Grid Name="PART_Content" Grid.Row="1">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                ContentTransitions="{TemplateBinding ContentTransitions}"
                                TextWrapping="Wrap" />
                        </Grid>


                        <!--  Footer  -->
                        <Grid
                            Name="PART_Footer"
                            Grid.Row="2"
                            Padding="24"
                            HorizontalAlignment="Stretch"
                            ColumnSpacing="8"
                            TabFocusNavigation="Cycle">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button
                                Name="PART_Button1"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Content="OK"
                                Style="{StaticResource AccentButtonStyle}" />
                            <Button
                                Name="PART_Button2"
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Content="Cancel" />
                            <Button
                                Name="PART_Button3"
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Content="Apply" />
                        </Grid>
                    </Grid>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

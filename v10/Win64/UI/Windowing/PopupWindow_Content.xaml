<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ImageGlass.Win64.UI.PopupWindow_Content"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.Win64.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:w64c="using:ImageGlass.Win64.Common"
    d:DataContext="{d:DesignInstance local:PopupWindow_Content,
                                     IsDesignTimeCreatable=True}"
    x:DefaultBindMode="OneWay"
    mc:Ignorable="d">


    <StackPanel
        x:Name="Root"
        Grid.Row="1"
        Padding="24,16,24,24"
        VerticalAlignment="Top"
        Background="{x:Bind w64c:AP.Config.Theme.ComputedColors.BgColor, Converter={StaticResource ColorToBrushConverter}}"
        Spacing="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>


            <Grid
                Margin="0,0,24,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Visibility="{x:Bind VM.IsThumbnailSectionVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                <!--  Thumbnail  -->
                <Border BorderBrush="Red" BorderThickness="0">
                    <Viewbox
                        x:Name="PART_ThumbnailViewbox"
                        Width="{x:Bind THUMBNAIL_SIZE}"
                        Height="{x:Bind THUMBNAIL_SIZE}"
                        Stretch="Uniform"
                        Visibility="{x:Bind VM.Thumbnail, Converter={StaticResource NullableToVisibilityConverter}}">
                        <Image
                            x:Name="PART_Thumbnail"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Viewbox>
                </Border>

                <!--  ThumbnailIcon  -->
                <Image
                    x:Name="PART_ThumbnailIcon"
                    Width="40"
                    Height="40"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Visibility="{x:Bind VM.ThumbnailIcon, Converter={StaticResource NullableToVisibilityConverter}}" />
            </Grid>


            <StackPanel
                Grid.Column="1"
                Orientation="Vertical"
                Spacing="16">

                <!--  Heading  -->
                <TextBlock
                    x:Name="PART_Heading"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    IsColorFontEnabled="True"
                    IsTextSelectionEnabled="True"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="{x:Bind VM.Heading}"
                    TextWrapping="WrapWholeWords"
                    Visibility="{x:Bind VM.Heading, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Description  -->
                <TextBlock
                    x:Name="PART_Description"
                    Foreground="{x:Bind w64c:AP.Config.Theme.ComputedColors.TextColor, Converter={StaticResource ColorToBrushConverter}}"
                    IsColorFontEnabled="True"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind VM.Description}"
                    TextWrapping="WrapWholeWords"
                    Visibility="{x:Bind VM.Description, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Input  -->
                <local:IgTextBox
                    x:Name="PART_Input"
                    AcceptValue="{x:Bind VM.AcceptValue}"
                    IsRequired="True"
                    Text="{x:Bind VM.InputValue}"
                    ValidateByPressingEnter="False"
                    Visibility="{x:Bind VM.IsInputVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!--  Details  -->
                <local:IgTextBox
                    x:Name="PART_Details"
                    MinHeight="50"
                    MaxHeight="150"
                    AcceptsReturn="True"
                    ContentFontFamily="Cascadia Mono, Consolas"
                    ContentFontSize="12"
                    ContentFontWeight="SemiLight"
                    IsReadOnly="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollMode="Enabled"
                    Text="{x:Bind VM.Details}"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind VM.Details, Converter={StaticResource StringToVisibilityConverter}}" />

            </StackPanel>
        </Grid>


        <StackPanel Spacing="8">
            <!--  Note  -->
            <InfoBar
                IsClosable="False"
                IsIconVisible="True"
                IsOpen="{x:Bind VM.Note, Converter={StaticResource StringToBoolConverter}}"
                Message="{x:Bind VM.Note}"
                Severity="{x:Bind VM.NoteStyle}" />

            <!--  RememberOption  -->
            <CheckBox x:Name="PART_Checkbox" Visibility="{x:Bind VM.IsRememberOptionVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock
                    Foreground="{x:Bind w64c:AP.Config.Theme.ComputedColors.TextColor, Converter={StaticResource ColorToBrushConverter}}"
                    Text="{x:Bind RememberOptionText}"
                    TextWrapping="WrapWholeWords" />
            </CheckBox>

        </StackPanel>
    </StackPanel>

</UserControl>

<?xml version="1.0" encoding="utf-8" ?>
<local:IgControl
    x:Class="ImageGlass.UI.DialogWindow_Content"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageGlass.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:DialogWindow_Content}"
    x:DefaultBindMode="OneWay"
    mc:Ignorable="d">

    <Grid
        x:Name="PART_Root"
        MaxWidth="{x:Bind MAX_WIDTH}"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        BackgroundSizing="InnerBorderEdge"
        KeyboardAcceleratorPlacementMode="Hidden"
        TabFocusNavigation="Cycle">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <!--  DialogContent  -->
        <Grid x:Name="PART_Content" Grid.Row="0">
            <ContentPresenter x:Name="PART_DialogContent" Content="{x:Bind DialogContent}" />
        </Grid>


        <!--  Footer  -->
        <StackPanel
            x:Name="PART_Footer"
            Grid.Row="1"
            HorizontalAlignment="Stretch">

            <StackPanel
                Padding="24"
                HorizontalAlignment="Right"
                KeyDown="FooterPanel_KeyDown"
                Orientation="Horizontal"
                Spacing="8"
                TabFocusNavigation="Once">

                <Button
                    Name="PART_Button1"
                    Grid.Column="0"
                    MinWidth="80"
                    Click="PART_Button1_Click"
                    Content="{x:Bind Button1Text}"
                    Visibility="{x:Bind Button1Visibility}" />
                <Button
                    Name="PART_Button2"
                    Grid.Column="1"
                    MinWidth="80"
                    Click="PART_Button2_Click"
                    Content="{x:Bind Button2Text}"
                    Visibility="{x:Bind Button2Visibility}" />
                <Button
                    Name="PART_Button3"
                    Grid.Column="2"
                    MinWidth="80"
                    Click="PART_Button3_Click"
                    Content="{x:Bind Button3Text}"
                    Visibility="{x:Bind Button3Visibility}" />
            </StackPanel>
        </StackPanel>
    </Grid>

</local:IgControl>

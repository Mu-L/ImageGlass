<Project>
  <!--
    Compose IgFullVersion and generate AppBuildInfo.g.cs for executable projects.
    The version is baked in as a const string. Fully AOT-safe, no reflection needed.
  -->

  <!-- Compose IgFullVersion, Version, FileVersion for executable projects -->
  <PropertyGroup Condition="'$(OutputType)' == 'WinExe' OR '$(OutputType)' == 'Exe'">
    <IgFullVersion Condition="'$(IgReleaseType)' != ''">$(IgVersion)-$(IgReleaseType)-$(IgPlatformId)-$(Platform)</IgFullVersion>
    <IgFullVersion Condition="'$(IgReleaseType)' == ''">$(IgVersion)-$(IgPlatformId)-$(Platform)</IgFullVersion>
    <Version>$(IgFullVersion)</Version>
    <FileVersion>$(IgVersion)</FileVersion>
  </PropertyGroup>


  <!-- Inline task: writes the C# source file without XML-escaped code -->
  <UsingTask TaskName="_GenerateVersionFile"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <OutputPath ParameterType="System.String" Required="true" />
      <Namespace ParameterType="System.String" Required="true" />
      <FullVersion ParameterType="System.String" Required="true" />
      <ReleaseType ParameterType="System.String" Required="true" />
      <UpdateChannel ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Code Type="Fragment" Language="cs">
      <![CDATA[
var code = $$"""
    // <auto-generated/>
    using ImageGlass.Common.Types;
    namespace ImageGlass.Common;
    
    internal class AppBuildInfo : IAppBuildInfo
    {
        public string AppVersion { get; } = "{{FullVersion}}";
        public string ReleaseType { get; } = "{{ReleaseType}}";
        public string UpdateChannel { get; } = "{{UpdateChannel}}";
    }
    """;

var dir = System.IO.Path.GetDirectoryName(OutputPath);
if (!string.IsNullOrEmpty(dir))
    System.IO.Directory.CreateDirectory(dir);

// Only write when content changed to avoid unnecessary rebuilds
if (!System.IO.File.Exists(OutputPath) || System.IO.File.ReadAllText(OutputPath) != code)
    System.IO.File.WriteAllText(OutputPath, code);
]]></Code>
    </Task>
  </UsingTask>


  <!-- Generate AppBuildInfo.g.cs -->
  <Target Name="GenerateAppBuildInfo"
          BeforeTargets="CoreCompile"
          DependsOnTargets="PrepareForBuild"
          Condition="'$(OutputType)' == 'WinExe' OR '$(OutputType)' == 'Exe'">
    <PropertyGroup>
      <_AppBuildInfoFile>$(IntermediateOutputPath)AppBuildInfo.g.cs</_AppBuildInfoFile>
    </PropertyGroup>
    <_GenerateVersionFile
        OutputPath="$(_AppBuildInfoFile)"
        Namespace="$(RootNamespace)"
        FullVersion="$(IgFullVersion)"
        ReleaseType="$(IgReleaseType)"
        UpdateChannel="$(IgUpdateChannel)" />
    <ItemGroup>
      <Compile Remove="$(_AppBuildInfoFile)" />
      <Compile Include="$(_AppBuildInfoFile)" />
    </ItemGroup>
  </Target>
</Project>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewer="using:ImageGlass.UI.Viewer"
             xmlns:vm="using:ImageGlass.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ImageGlass.Views.MainView"
             x:DataType="vm:MainViewModel">
    <viewer:ViewerControl>
		<TextBlock Text="{CompiledBinding Title}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </viewer:ViewerControl>
</UserControl>

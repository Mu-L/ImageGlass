<uiw:PhWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uiw="using:ImageGlass.UI.Windowing"
        xmlns:wv="using:ImageGlass.Common.Windows"
        xmlns:vm="using:ImageGlass.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ImageGlass.Common.Windows.MainWindow"
        x:DataType="vm:MainWindowModel"
        BackdropStyle="{CompiledBinding Config.WindowBackdrop}"
        IsFrameless="{CompiledBinding Config.EnableFrameless}"
        Title="{CompiledBinding Title}">

  <wv:MainWindowView x:Name="PART_MainView" DataContext="{CompiledBinding .}" />

</uiw:PhWindow >

<win:PhWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:win="using:ImageGlass.UI.Windowing"
        xmlns:view="using:ImageGlass.Views"
        xmlns:vm="using:ImageGlass.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ImageGlass.Common.Windows.MainWindow"
        x:DataType="vm:MainWindowModel"
        BackdropStyle="{CompiledBinding Config.WindowBackdrop}"
        IsFrameless="{CompiledBinding Config.EnableFrameless}"
        Title="{CompiledBinding Title}">

  <view:MainView x:Name="PART_MainView" DataContext="{CompiledBinding .}"></view:MainView>

</win:PhWindow >

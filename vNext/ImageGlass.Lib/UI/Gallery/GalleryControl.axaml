<ui:PhControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:ImageGlass.UI"
             xmlns:cm="using:ImageGlass.Common"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="200"
             x:Class="ImageGlass.UI.GalleryControl"
             x:DataType="ui:GalleryControlModel">
    <ItemsControl x:Name="PART_ItemsControl"
                  ItemsSource="{CompiledBinding ItemsSource, RelativeSource={RelativeSource AncestorType=ui:GalleryControl}}">

        <!-- GalleryControl: Control template -->
        <ItemsControl.Template>
            <ControlTemplate>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                              VerticalScrollBarVisibility="Auto"
                              IsScrollInertiaEnabled="True"
                              PointerWheelChanged="PART_ScrollViewer_PointerWheelChanged">
                    <Border Padding="4,4,4,8">
						<ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" />
                    </Border>
                </ScrollViewer>
            </ControlTemplate>
        </ItemsControl.Template>


        <!-- GalleryControl: Layout template -->
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <VirtualizingStackPanel HorizontalAlignment="Center"
                                        Orientation="{CompiledBinding Orientation, RelativeSource={RelativeSource AncestorType=ui:GalleryControl}}" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>


        <!-- GalleryControl: Item template -->
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <ui:GalleryItem
                    Margin="1"
                    IsTabStop="False"
                    Width="{CompiledBinding ThumbnailSize, Source={x:Static cm:Core.Config}}"
                    Height="{CompiledBinding ThumbnailSize, Source={x:Static cm:Core.Config}}"
                    Click="GalleryItem_Click" />
            </DataTemplate>
        </ItemsControl.ItemTemplate>
        
    </ItemsControl>
</ui:PhControl>

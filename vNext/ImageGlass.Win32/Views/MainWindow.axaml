<ui32:Win32Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ImageGlass.Win32.Models"
        xmlns:ui32="using:ImageGlass.Win32.UI"
        xmlns:v="using:ImageGlass.Win32.Views"
        xmlns:local="using:ImageGlass.UI.Viewer"
        xmlns:cm="clr-namespace:ImageGlass.Common.Core"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ImageGlass.Win32.Views.MainWindow" 
        x:DataType="vm:MainWindowModel"
        x:CompileBindings="True"
        BackdropStyle="{CompiledBinding Config.WindowBackdrop}"
        IsFrameless="{CompiledBinding Config.EnableFrameless}"
        Icon="/Assets/avalonia-logo.ico"
        Title="{CompiledBinding Title}">

    <local:ViewerControl x:Name="Viewer">
		<TextBlock Text="{CompiledBinding Title}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </local:ViewerControl>
    

</ui32:Win32Window>

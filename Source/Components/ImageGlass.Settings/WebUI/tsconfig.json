{
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./src/@types"],
    "rootDir": "./",
    "outDir": "./dist/dist",
    "noImplicitAny": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": ["node_modules"]
}

